model ProjectSpec {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filePath  String   // Vercel Blob URL to specs/{projectId}/{specId}.md
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}
